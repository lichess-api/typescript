{
  "name": "@lichess/api",
  "version": "0.1.1",
  "keywords": [
    "api",
    "lichess"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lichess-api/typescript.git"
  },
  "license": "MIT",
  "author": "gameroman",
  "type": "module",
  "imports": {
    "#lib/*": "./src/lib/*.ts",
    "#schemas": "./src/schemas/index.ts"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./schemas": "./dist/schemas.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bunx --bun tsdown",
    "format": "biome check --write --linter-enabled=false",
    "gen": "bun run --sequential gen:schemas gen:client format",
    "gen:client": "bun ./scripts/gen-client",
    "gen:schemas": "bun ./scripts/gen-schemas",
    "lint": "biome check",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "minizod": "0.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@gameroman/config": "0.2.2",
    "@types/bun": "1.3.14",
    "@typescript/native-preview": "7.0.0-dev.20260627.2",
    "tsdown": "0.22.3",
    "zod": "4.3.6"
  },
  "engines": {
    "node": ">=24"
  }
}
